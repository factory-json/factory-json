{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://factoryschema.org/v2.0/factory.schema.json",
  "title": "factory.md frontmatter",
  "description": "Validates the YAML frontmatter of a factory.md file — a machine-readable manufacturing facility profile.",
  "type": "object",
  "required": ["name", "location"],

  "properties": {
    "schema": {
      "type": "string",
      "const": "https://factoryschema.org/v2.0/factory.schema.json",
      "description": "Must reference this schema."
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Trade name of the factory."
    },
    "location": {
      "description": "Factory location as a string (\"City, CC\") or a structured object.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": ["city", "country"],
          "properties": {
            "city": { "type": "string", "minLength": 1 },
            "region": { "type": "string" },
            "country": {
              "type": "string",
              "pattern": "^[A-Z]{2}$",
              "description": "ISO 3166-1 alpha-2 country code."
            },
            "postal_code": { "type": "string" },
            "timezone": {
              "type": "string",
              "description": "IANA timezone (e.g. \"Asia/Shanghai\")."
            },
            "coordinates": {
              "type": "object",
              "required": ["lat", "lng"],
              "properties": {
                "lat": { "type": "number", "minimum": -90, "maximum": 90 },
                "lng": { "type": "number", "minimum": -180, "maximum": 180 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "vertical": {
      "type": "string",
      "description": "Primary industry vertical (free-form, e.g. \"machining\", \"pcb\", \"textiles\")."
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Manufacturing processes offered (free-form strings)."
    },
    "certifications": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "minLength": 1, "description": "Certification name (e.g. \"ISO 9001:2015\", \"GOTS\")." },
          "body": { "type": "string", "description": "Issuing / certifying body." },
          "id": { "type": "string", "description": "Certificate ID or number." },
          "issued": { "type": "string", "format": "date", "description": "Date issued (YYYY-MM-DD)." },
          "expires": { "type": "string", "format": "date", "description": "Expiry date (YYYY-MM-DD)." },
          "url": { "type": "string", "format": "uri", "description": "Link to certificate or verification page." }
        },
        "additionalProperties": false
      },
      "description": "Industry certifications and compliance credentials."
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Factory website URL."
    },
    "email": {
      "type": "string",
      "description": "Contact email address."
    }
  },

  "additionalProperties": false
}
